//- 1. DEFINIÇÃO DO MIXIN (A "Função" que cria o layout do card)
mixin projetoCard(nome, tecnologia, status)
  .card(style="border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 10px; box-shadow: 2px 2px 5px rgba(0,0,0,0.05); font-family: sans-serif;")
    h3(style="margin-top: 0; color: #333;")= nome
    p(style="color: #666;") 🛠️ Tecnologia: 
      strong #{tecnologia}
    
    //- Lógica condicional para as cores do status
    if status == 'Ativo'
      span(style="color: #27ae60; font-weight: bold;") ● #{status}
    else if status == 'Em Pausa'
      span(style="color: #f39c12; font-weight: bold;") 🟠 #{status}
    else
      span(style="color: #95a5a6; font-weight: bold;") ○ #{status}

//- 2. ESTRUTURA DO DOCUMENTO
doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    title Dashboard do João Lucas
  body(style="max-width: 800px; margin: 0 auto; padding: 40px; background-color: #f9f9f9;")
    
    header(style="border-bottom: 2px solid #eee; margin-bottom: 30px; padding-bottom: 10px;")
      h1 Dashboard de Projetos do Jolito 🚀
      p(style="color: #777;") Desenvolvedor Back-end em formação | Sorocaba, SP

    //- 3. DADOS (Simulando o que viria de um Banco de Dados ou API)
    - 
      var meusProjetos = [
        { nome: 'Pokemon Scraper', tech: 'Python', status: 'Ativo' },
        { nome: 'Smart Trash Can', tech: 'Arduino', status: 'Ativo' },
        { nome: 'Cybersecurity Bootcamp', tech: 'Security', status: 'Finalizado' },
        { nome: 'Facens Vault', tech: 'Markdown/GitHub', status: 'Ativo' },
        { nome: 'Sistema MEI', tech: 'Go/PostgreSQL', status: 'Em Pausa' }
      ]

    //- 4. O LOOP (Iteração sobre os dados)
    section.projetos
      each p in meusProjetos
        +projetoCard(p.nome, p.tech, p.status)

    footer(style="margin-top: 50px; font-size: 0.8em; color: #aaa; text-align: center;")
      p Gerado dinamicamente via Pug Template Engine.
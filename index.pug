mixin projetoCard(nome, tecnologia, status)
  .card
    h3= nome
    p.tech-text 🛠️ Tecnologia: 
      strong #{tecnologia}
    
    //- Agora usamos classes CSS ao invés de estilos inline
    if status == 'Ativo'
      span.status.status-ativo ● #{status}
    else if status == 'Em Pausa'
      span.status.status-pausa 🟠 #{status}
    else
      span.status.status-finalizado ○ #{status}

doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    title Dashboard do João Lucas
    //- Conectando o arquivo CSS (usamos ../ porque o HTML vai estar dentro da pasta dist)
    link(rel="stylesheet", href="style.css")
  
  body
    header
      h1 Dashboard de Projetos do Jolito 🚀
      p.subtitle Desenvolvedor Back-end em formação | Sorocaba, SP

    - 
      var meusProjetos = [
        { nome: 'Pokemon Scraper', tech: 'Python', status: 'Ativo' },
        { nome: 'Smart Trash Can', tech: 'Arduino', status: 'Ativo' },
        { nome: 'Cybersecurity Bootcamp', tech: 'Security', status: 'Finalizado' },
        { nome: 'Facens Vault', tech: 'Markdown/GitHub', status: 'Ativo' },
        { nome: 'Sistema MEI', tech: 'Go/PostgreSQL', status: 'Em Pausa' }
      ]

    section.projetos
      each p in meusProjetos
        +projetoCard(p.nome, p.tech, p.status)

    footer
      p Gerado dinamicamente via Pug e estilizado com CSS externo.